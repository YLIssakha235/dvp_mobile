model Comment {
  id         String   @id @default(cuid())
  message    String

  incidentId String
  incident   Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)

  authorId String
  author   User     @relation(fields: [authorId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([incidentId])
  @@index([authorId])
  @@map("comment")
}
