enum IncidentStatus {
  OPEN
  ASSIGNED
  IN_PROGRESS
  RESOLVED
  APPROVED
  READY_TO_EXPORT
  EXPORTED
}


enum IncidentPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}


model Incident {
  id          String           @id @default(cuid())
  title       String
  description String

  status      IncidentStatus   @default(OPEN)
  priority    IncidentPriority @default(MEDIUM)

  // Localisation terrain
  latitude      Float?
  longitude     Float?
  locationLabel String?

  // Relations utilisateurs
  createdById  String
  createdBy    User   @relation("IncidentCreatedBy", fields: [createdById], references: [id], onDelete: Cascade)

  assignedToId String?
  assignedTo   User?  @relation("IncidentAssignedTo", fields: [assignedToId], references: [id], onDelete: SetNull)

  // Résolution (technico-fonctionnelle)
  workSummary String?
  resolvedAt  DateTime?

  // Validation manager + coûts (déclaratif)
  approvedById String?
  approvedBy   User?   @relation("IncidentApprovedBy", fields: [approvedById], references: [id], onDelete: SetNull)
  approvedAt   DateTime?

  estimatedMinutes Int?
  actualMinutes    Int?

  estimatedCostCents Int?
  actualCostCents    Int?
  currency           String @default("EUR")
  costNote           String?

  // Export
  externalSystem     String?
  externalIncidentId String?
  exportedAt         DateTime?

  // Dates système
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations contenu
  assets      Asset[]
  comments    Comment[]

  @@index([status])
  @@index([priority])
  @@index([createdById])
  @@index([assignedToId])
  @@map("incident")
}
